{
	"autosu": true,
	"detectlimit": 1000,
	"diffgutter": true,
	"rmtrailingws": true,
	"statusformatl": " $(modified)$(filename) • L:$(lines) R:$(line) C:$(col) $(status.paste)",
	"statusformatr": "$(opt:encoding) • $(opt:fileformat) • $(opt:filetype) ",
	"tabsize": 4,
	"tabstospaces": false,
	"keymenu": true,
	"mkparents": true,
	"scrollbar": true,
	"scrollspeed": 4,
}
