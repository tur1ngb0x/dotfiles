  // sudo mkdir -pv /etc/brave/policies/managed && sudo cp -fv ./custom.json /etc/brave/policies/managed/custom.json
  "BraveAIChatEnabled": false,
  "BraveRewardsDisabled": true,
  "BraveVPNDisabled": true,
  "BraveWalletDisabled": true,
  "TorDisabled": true,

  // Edge
  // sudo mkdir -pv /etc/opt/edge/policies/managed && sudo cp -fv ./custom.json /etc/opt/edge/policies/managed/custom..json
